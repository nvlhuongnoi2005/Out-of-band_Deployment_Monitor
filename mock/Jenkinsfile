// Jenkins pipeline for webapp-deploy job.
// Automatically opens/closes the OOB Deploy Window so the monitor
// classifies Ansible file changes as AUTHORIZED_CHANGE, not UNAUTHORIZED_DRIFT.
//
// Configure in Jenkins:
//   New Item → Pipeline → Pipeline script from SCM → this file
//   Or paste into Pipeline script directly.

pipeline {
    agent any

    environment {
        // IP of the host machine reachable from inside the Jenkins container.
        // On Docker Desktop / Linux: use host.docker.internal or 172.17.0.1
        CENTRAL_URL = 'http://172.17.0.1:8080'
        OOB_PROJECT = 'webapp'
        OOB_SERVER  = 'local-demo'
        // Deploy window stays open for 10 minutes; Central auto-closes if CLOSE not received.
        VALID_UNTIL = sh(returnStdout: true,
                         script: "date -u -d '+10 minutes' '+%Y-%m-%dT%H:%M:%S+00:00'").trim()
    }

    stages {
        stage('Open Deploy Window') {
            steps {
                sh """
                    curl -sf -X POST ${CENTRAL_URL}/api/v1/deploy-window \\
                         -H 'Content-Type: application/json' \\
                         -d '{"action":"OPEN","project":"${OOB_PROJECT}","server":"${OOB_SERVER}","valid_until":"${VALID_UNTIL}"}'
                    echo "Deploy window opened until ${VALID_UNTIL}"
                """
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    echo "=== Simulating Ansible deploy ==="
                    mkdir -p /tmp/demo-prod-app/config

                    echo '{"version":"2.0.0","deployed_by":"jenkins","env":"prod"}' \
                        > /tmp/demo-prod-app/config/app.json

                    echo '[database]\nhost=db.internal\nport=5432' \
                        > /tmp/demo-prod-app/config/db.conf

                    echo "Deploy done at $(date)"
                '''
            }
        }
    }

    post {
        always {
            sh """
                curl -sf -X POST ${CENTRAL_URL}/api/v1/deploy-window \\
                     -H 'Content-Type: application/json' \\
                     -d '{"action":"CLOSE","project":"${OOB_PROJECT}","server":"${OOB_SERVER}"}' || true
                echo "Deploy window closed"
            """
        }
        success { echo "Pipeline succeeded — AUTHORIZED_CHANGE expected in OOB monitor" }
        failure { echo "Pipeline failed  — Deploy window closed to avoid stale authorization" }
    }
}
