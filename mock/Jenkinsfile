// Pipeline: webapp deploy + remediation
//
// Luồng bình thường (CI/CD):
//   Jenkins mở Deploy Window → Ansible SSH vào VM → restore/deploy file → đóng window
//   Agent trên VM phát hiện thay đổi → Central phân loại AUTHORIZED_CHANGE
//
// Luồng remediation (tự động từ Central):
//   Central phát hiện UNAUTHORIZED_DRIFT → POST /job/webapp/build (không có tham số)
//   → Jenkins chạy pipeline với VM_IP mặc định → restore file về đúng trạng thái

pipeline {
    agent any

    parameters {
        string(
            name: 'VM_IP',
            defaultValue: '192.168.1.16',
            description: 'IP của VM đang chạy oob-agent'
        )
        string(
            name: 'VM_USER',
            defaultValue: 'lap',
            description: 'SSH user trên VM'
        )
        string(
            name: 'OOB_SERVER_NAME',
            defaultValue: 'prod-server-01',
            description: 'Phải khớp với trường "server" trong agent config'
        )
    }

    environment {
        // Jenkins chạy trong Docker; giao tiếp với oob-central trên host qua Docker bridge.
        CENTRAL_URL = 'http://172.17.0.1:8080'
        OOB_PROJECT = 'webapp'
        OOB_SERVER  = "${params.OOB_SERVER_NAME}"
        VALID_UNTIL = sh(
            returnStdout: true,
            script: "date -u -d '+10 minutes' '+%Y-%m-%dT%H:%M:%S+00:00'"
        ).trim()
    }

    stages {
        stage('Open Deploy Window') {
            steps {
                sh """
                    curl -sf -X POST ${CENTRAL_URL}/api/v1/deploy-window \\
                         -H 'Content-Type: application/json' \\
                         -d '{"action":"OPEN","project":"${OOB_PROJECT}","server":"${OOB_SERVER}","valid_until":"${VALID_UNTIL}"}'
                    echo "Deploy window opened until ${VALID_UNTIL}"
                """
            }
        }

        stage('Restore files on VM') {
            steps {
                // Yêu cầu: credential 'vm-deploy-key' (SSH private key) trong Jenkins
                // Jenkins → Manage Jenkins → Credentials → Add → SSH Username with private key
                sshagent(credentials: ['vm-deploy-key']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${params.VM_USER}@${params.VM_IP} '
                            mkdir -p /tmp/demo-prod-app/config /tmp/demo-prod-app/scripts
                            echo "{\"version\":\"2.0.0\",\"deployed_by\":\"jenkins\",\"env\":\"prod\"}" \\
                                > /tmp/demo-prod-app/config/app.json
                            printf "[database]\nhost=db.internal\nport=5432\npool=10\n" \\
                                > /tmp/demo-prod-app/config/db.conf
                            echo "Restored by Jenkins at \$(date)"
                        '
                    """
                }
            }
        }
    }

    post {
        always {
            sh """
                curl -sf -X POST ${CENTRAL_URL}/api/v1/deploy-window \\
                     -H 'Content-Type: application/json' \\
                     -d '{"action":"CLOSE","project":"${OOB_PROJECT}","server":"${OOB_SERVER}"}' || true
                echo "Deploy window closed"
            """
        }
        success { echo "Pipeline OK — AUTHORIZED_CHANGE expected in OOB monitor" }
        failure { echo "Pipeline FAILED — Deploy window closed, files may not be restored" }
    }
}
